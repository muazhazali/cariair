# =============================================================================
# CariAir Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For Docker: These are pre-configured in docker-compose.yml
# For local dev: Update with your PostgreSQL credentials

DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASS="postgres"
DB_NAME="cariair"

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------
# Required for authentication. Generate a secret with:
# openssl rand -base64 32

AUTH_SECRET="change-this-to-a-random-secret-key"

# Google OAuth credentials (optional for local development)
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# Optional: Analytics
# -----------------------------------------------------------------------------
# Umami analytics script URL (optional)
# NEXT_PUBLIC_UMAMI_URL=""
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
